---
const currentYear = new Date().getFullYear();
---

<footer class="dark-section site-footer">

    <!-- Zone 1: Newsletter -->
    <div class="footer-newsletter reveal">
        <span class="section-label">Stay Informed</span>
        <p class="narrative footer-headline">
            Insights on strategy, design, and the future of work&mdash;delivered when it matters.
        </p>
        <form class="newsletter-form" action="https://levy.outseta.com/email/lists/MQvb4oQY/subscribe" method="post">
            <div class="newsletter-input-group">
                <label for="footer-email" class="sr-only">Email address</label>
                <input
                    type="email"
                    id="footer-email"
                    name="Email"
                    class="newsletter-input"
                    placeholder="Your email address"
                    required
                    autocomplete="email"
                />
                <button type="submit" class="newsletter-btn" data-wait="Sending...">Subscribe</button>
            </div>
            <!-- Honeypot — must be empty; wrong name causes bot-flagging of real signups -->
            <div style="position: absolute; left: -5000px;" aria-hidden="true">
                <input type="text" name="o_q24bClZJMfnImoR5BAUXwhkf_y1uZ3Ifp" tabindex="-1" value="" autocomplete="off" />
            </div>
            <p class="micro-data newsletter-privacy">No spam. Unsubscribe anytime.</p>
        </form>
        <script src="https://cdn.outseta.com/emailsignup.min.js" defer is:inline></script>
    </div>

    <hr class="footer-divider" />

    <!-- Zone 2: Navigation -->
    <nav class="footer-nav reveal" aria-label="Footer navigation">
        <div class="footer-nav-col">
            <span class="footer-nav-heading">Company</span>
            <ul class="footer-nav-list">
                <li><a href="/about">About</a></li>
                <li><a href="/studio">Studio</a></li>
                <li><a href="/join">Join</a></li>
            </ul>
        </div>
        <div class="footer-nav-col">
            <span class="footer-nav-heading">Resources</span>
            <ul class="footer-nav-list">
                <li><a href="/insights">Insights</a></li>
                <li><a href="/join">Membership</a></li>
                <li class="anonymous-only"><a href="/login">Login</a></li>
                <li class="member-only"><a href="/dashboard">Dashboard</a></li>
                <li class="member-only"><a href="/dashboard/account">My Account</a></li>
            </ul>
        </div>
        <div class="footer-nav-col">
            <span class="footer-nav-heading">Connect</span>
            <ul class="footer-nav-list">
                <li><a href="mailto:hello@levy.design">hello@levy.design</a></li>
                <li><span>Washington, D.C.</span></li>
            </ul>
        </div>
    </nav>

    <hr class="footer-divider" />

    <!-- Zone 3: Copyright -->
    <div class="footer-bottom reveal">
        <span class="micro-data">&copy; {currentYear} Levy Strategic Design</span>
        <span class="micro-data">Washington, D.C.</span>
    </div>

</footer>

<style>
    .site-footer {
        display: flex;
        flex-direction: column;
        padding: var(--space-18) 5vw var(--space-12);
        border-bottom: none;
    }

    /* Zone 1: Newsletter */
    .footer-newsletter {
        max-width: 640px;
    }

    .footer-headline {
        margin-top: var(--space-3);
        max-width: 20ch;
        font-size: clamp(1.333rem, 3.5vw, var(--step-3));
        color: rgba(245, 245, 243, 0.7);
    }

    .newsletter-form {
        margin-top: var(--space-6);
        position: relative;
    }

    .newsletter-input-group {
        display: flex;
        position: relative;
    }

    .newsletter-input-group::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0;
        width: 100%;
        height: 2px;
        background: var(--paper);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.5s var(--ease-out-expo);
    }

    .newsletter-input-group:focus-within::after {
        transform: scaleX(1);
    }

    .newsletter-input {
        flex: 1;
        height: var(--space-6);
        padding: 0 var(--space-3);
        background: rgba(245, 245, 243, 0.05);
        border: var(--stroke-weight) solid rgba(245, 245, 243, 0.15);
        border-right: none;
        color: var(--paper);
        font-family: var(--font-tech);
        font-size: var(--step-0);
        font-weight: 300;
        transition: border-color 0.3s var(--ease-out-expo), background 0.3s var(--ease-out-expo);
    }

    .newsletter-input:focus {
        border-color: var(--paper);
        background: rgba(245, 245, 243, 0.08);
        outline: none;
    }

    .newsletter-input::placeholder {
        color: rgba(245, 245, 243, 0.4);
    }

    .newsletter-btn {
        height: var(--space-6);
        padding: 0 var(--space-4);
        background: var(--paper);
        color: var(--midnight);
        border: var(--stroke-weight) solid var(--paper);
        font-family: var(--font-tech);
        font-size: var(--step--1);
        font-weight: 300;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        white-space: nowrap;
        flex-shrink: 0;
        transition: background 0.3s var(--ease-out-expo), color 0.3s var(--ease-out-expo);
    }

    .newsletter-btn:hover {
        background: transparent;
        color: var(--paper);
    }

    .newsletter-privacy {
        margin-top: var(--space-2);
        color: rgba(245, 245, 243, 0.4);
    }

    /* Divider */
    .footer-divider {
        border: none;
        border-top: var(--stroke-weight) solid rgba(245, 245, 243, 0.15);
        margin: var(--space-12) 0;
    }

    /* Zone 2: Navigation */
    .footer-nav {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-8);
    }

    .footer-nav-heading {
        font-family: var(--font-tech);
        font-size: var(--step--1);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--paper);
        display: block;
        margin-bottom: var(--space-3);
    }

    .footer-nav-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .footer-nav-list li,
    .footer-nav-list a,
    .footer-nav-list span {
        font-family: var(--font-tech);
        font-size: var(--step--1);
        font-weight: 300;
        color: rgba(245, 245, 243, 0.7);
        text-decoration: none;
        transition: color 0.3s var(--ease-out-expo);
    }

    .footer-nav-list a:hover {
        color: var(--paper);
    }

    /* Auth-state-aware footer links: default state mirrors anonymous so
       there is no flash of member links on first paint. */
    .footer-nav-list .member-only { display: none; }
    :global(body.is-authenticated) .footer-nav-list .member-only { display: list-item; }
    :global(body.is-authenticated) .footer-nav-list .anonymous-only { display: none; }

    /* Zone 3: Copyright */
    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .footer-bottom .micro-data {
        color: rgba(245, 245, 243, 0.4);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .footer-nav {
            grid-template-columns: 1fr 1fr;
            gap: var(--space-6);
        }
    }

    @media (max-width: 480px) {
        .site-footer {
            padding: var(--space-12) 4vw var(--space-8);
        }

        .newsletter-input-group {
            flex-direction: column;
        }

        .newsletter-input {
            border-right: var(--stroke-weight) solid rgba(245, 245, 243, 0.15);
        }

        .newsletter-btn {
            width: 100%;
            margin-top: var(--space-2);
        }

        .footer-nav {
            grid-template-columns: 1fr;
            gap: var(--space-6);
        }

        .footer-bottom {
            flex-direction: column;
            gap: var(--space-2);
            align-items: flex-start;
        }
    }
</style>
