---
interface Props {
    label: string;
    checked?: boolean;
    name?: string;
}

const { label, checked = false, name } = Astro.props;
---

<label class="control-label">
    <input type="checkbox" checked={checked} name={name}>
    <div class="control-box"></div> {label}
</label>

<style>
    .control-label { display: flex; align-items: center; gap: var(--space-2); cursor: pointer; font-family: var(--font-tech); font-size: var(--step-0); }
    .control-label input { position: absolute; opacity: 0; cursor: pointer; height: 0; width: 0; }
    .control-box { height: var(--space-3); width: var(--space-3); background: transparent; border: var(--stroke-weight) solid var(--stroke-color); display: flex; align-items: center; justify-content: center; transition: background 0.2s, border-color 0.2s; }
    .control-label input:checked ~ .control-box { background: var(--ink); border-color: var(--ink); }
    .control-box::after { content: ""; display: none; width: var(--space-1); height: var(--space-1); background: var(--paper); }
    .control-label input:checked ~ .control-box::after { display: block; }
</style>
