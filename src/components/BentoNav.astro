---
interface NavItem {
    href: string;
    number: string;
    category: string;
    title: string;
    wide?: boolean;
}

interface Props {
    items: NavItem[];
    currentPath?: string;
}

const { items, currentPath } = Astro.props;
---

<nav class="bento-nav" id="bentoNav" aria-label="Main navigation">
    <div style="width: 100%; max-width: 2400px; margin: 0 auto; height: 100%;">
        <div class="bento-grid">
            {items.map((item, i) => (
                <a href={item.href} class:list={["bento-item", { wide: item.wide, "is-current": currentPath === item.href || (item.href !== '/' && currentPath?.startsWith(item.href)) }]} style={`--item-index: ${i}`} aria-current={currentPath === item.href ? "page" : undefined}>
                    <span class="tech-subhead">{item.number} // {item.category}</span>
                    <h3 class="tech-title display-medium">{item.title}</h3>
                </a>
            ))}
        </div>
    </div>
</nav>

<style>
    .bento-nav {
        position: fixed; top: 0; left: 0; width: 100%; height: 100dvh; background: rgba(15, 12, 41, 0.98);
        z-index: 1500; padding: calc(var(--header-height) + var(--space-4)) 5vw var(--space-8) 5vw;
        opacity: 0; visibility: hidden; transition: opacity 0.5s var(--ease-out-expo), visibility 0.5s; overflow-y: auto;
    }
    .bento-nav.is-open { opacity: 1; visibility: visible; pointer-events: auto; }
    .bento-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-1); height: 100%; max-height: 80dvh; max-width: 2000px; margin: 0 auto; }

    .bento-item {
        background: var(--midnight); border: var(--stroke-weight) solid var(--stroke-light); padding: var(--space-4);
        text-decoration: none; color: var(--paper); display: flex; flex-direction: column; justify-content: space-between;
        min-height: var(--space-24);
        opacity: 0; transform: translateY(16px) scale(0.97);
        transition: transform 0.6s var(--ease-out-expo),
                    opacity 0.5s var(--ease-out-expo),
                    border-color 0.4s,
                    background 0.4s;
        transition-delay: calc(var(--item-index, 0) * 0.06s);
    }
    .bento-item.wide { grid-column: span 2; }
    .bento-item .tech-subhead { color: rgba(245, 245, 243, 0.6); }
    .bento-item:hover { border-color: var(--paper); background: rgba(245, 245, 243, 0.04); }
    .bento-item.is-current { border-color: var(--paper); background: rgba(245, 245, 243, 0.06); }
    .bento-nav.is-open .bento-item { opacity: 1; transform: translateY(0) scale(1); }

    @media (max-width: 1024px) {
        .bento-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
        .bento-grid { grid-template-columns: 1fr; max-height: none; }
        .bento-item { min-height: var(--space-16); padding: var(--space-3); }
        .bento-item.wide { grid-column: span 1; }
    }
</style>
