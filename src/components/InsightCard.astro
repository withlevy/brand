---
interface Props {
    title: string;
    href: string;
    date: Date;
    excerpt: string;
}

const { title, href, date, excerpt } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
    month: 'short',
    year: 'numeric',
}).toUpperCase();
---

<a href={href} class="insight-card">
    <span class="micro-data insight-date">{formattedDate}</span>
    <h3 class="tech-title insight-title">{title}</h3>
    <p class="body-medium insight-excerpt">{excerpt}</p>
    <span class="micro-data insight-cta">Read more &rarr;</span>
</a>

<style>
    .insight-card {
        background: var(--paper);
        width: 100%;
        padding: var(--space-6);
        border: var(--stroke-weight) solid var(--stroke-color);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        text-decoration: none;
        color: inherit;
        transition: transform 0.4s var(--ease-out-expo),
                    box-shadow 0.4s var(--ease-out-expo),
                    border-color 0.4s var(--ease-out-expo);
    }

    .insight-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(15, 12, 41, 0.08);
        border-color: rgba(15, 12, 41, 0.5);
    }

    .insight-date {
        color: var(--ink-muted);
    }

    .insight-title {
        font-size: var(--step-1);
        margin-top: var(--space-1);
    }

    .insight-excerpt {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    .insight-cta {
        margin-top: var(--space-3);
        color: var(--ink);
        font-weight: 500;
        transition: color 0.3s var(--ease-out-expo);
    }

    .insight-card:hover .insight-cta {
        color: var(--ink-muted);
    }

    @media (max-width: 768px) {
        .insight-card {
            padding: var(--space-4);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .insight-card:hover {
            transform: none;
        }
    }
</style>
