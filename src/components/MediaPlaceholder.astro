---
interface Props {
    ratio?: '16:9' | '4:3' | '1:1';
    caption?: string;
}

const { ratio = '16:9', caption } = Astro.props;

const ratioClass = {
    '16:9': 'ratio-16-9',
    '4:3': 'ratio-4-3',
    '1:1': 'ratio-1-1',
}[ratio];
---

<div>
    <div class:list={["media-placeholder", ratioClass]}></div>
    {caption && <span class="caption">{caption}</span>}
</div>

<style>
    .media-placeholder {
        width: 100%; background: rgba(15, 12, 41, 0.02); border: var(--stroke-weight) solid var(--stroke-color);
        display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;
        background-image: repeating-linear-gradient(45deg, var(--stroke-color) 0, var(--stroke-color) 1px, transparent 1px, transparent 12px);
    }
    .media-placeholder::after {
        content: 'MEDIA MANIFEST'; position: absolute; background: var(--paper); padding: var(--space-1) var(--space-2);
        border: var(--stroke-weight) solid var(--stroke-color); font-family: var(--font-tech); font-weight: 300; font-size: var(--step--2); text-transform: uppercase; letter-spacing: 0.05em;
    }
    .ratio-16-9 { aspect-ratio: 16 / 9; }
    .ratio-4-3 { aspect-ratio: 4 / 3; }
    .ratio-1-1 { aspect-ratio: 1 / 1; }

    .caption { font-family: var(--font-tech); font-size: var(--step--1); font-weight: 300; color: var(--ink-muted); margin-top: var(--space-2); display: block;}
</style>
