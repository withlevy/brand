---
interface Props {
    label: string;
    placeholder?: string;
}

const { label, placeholder } = Astro.props;
---

<div class="form-row">
    <label class="form-label">{label}</label>
    <textarea class="form-textarea" placeholder={placeholder}></textarea>
</div>

<style>
    .form-row { display: flex; flex-direction: column; gap: var(--space-1); margin-bottom: var(--space-4); width: 100%; }
    .form-label { font-family: var(--font-tech); font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink); }

    .form-textarea {
        width: 100%; padding: var(--space-2) var(--space-3);
        background: transparent; border: var(--stroke-weight) solid var(--stroke-color);
        color: var(--ink); font-family: var(--font-tech); font-size: var(--step-0); font-weight: 300; transition: border-color 0.3s var(--ease-out-expo);
        resize: vertical; min-height: var(--space-16); height: auto;
    }
    .form-textarea:focus { outline: none; border-color: var(--ink); }
    .form-textarea::placeholder { color: var(--ink-muted); opacity: 0.5; }
</style>
