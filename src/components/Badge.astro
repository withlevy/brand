---
interface Props {
    label: string;
    opacity?: number;
}

const { label, opacity } = Astro.props;
---

<span class="badge" style={opacity !== undefined ? `opacity: ${opacity}` : undefined}>{label}</span>

<style>
    .badge {
        display: inline-flex; align-items: center; height: var(--space-4); padding: 0 var(--space-2);
        border: var(--stroke-weight) solid var(--stroke-color); background: rgba(15, 12, 41, 0.03);
        font-family: var(--font-tech); font-size: var(--step--2); text-transform: uppercase; letter-spacing: 0.1em;
    }
</style>
