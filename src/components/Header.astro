---

---

<header id="mainHeader">
    <div class="header-inner">
        <a href="/" class="header-logo">
            <img src="/logo-header.png" alt="Levy" class="header-logo-img" loading="lazy" />
        </a>
        <div class="header-actions">
            <a href="/login" class="header-login">Login</a>
            <button class="hamburger" id="navToggle" aria-expanded="false" aria-controls="bentoNav" aria-label="Toggle Navigation">
                <div class="hamburger-box">
                    <span></span><span></span>
                </div>
            </button>
        </div>
    </div>
</header>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const navToggle = document.getElementById('navToggle');
        const bentoNav = document.getElementById('bentoNav');
        const navLinks = document.querySelectorAll('.bento-item');
        const mainHeader = document.getElementById('mainHeader');

        navToggle?.addEventListener('click', () => {
            const isOpen = bentoNav!.classList.toggle('is-open');
            navToggle.classList.toggle('is-active');
            navToggle.setAttribute('aria-expanded', String(isOpen));
            document.body.style.overflow = isOpen ? 'hidden' : '';

            if (isOpen) {
                mainHeader!.classList.add('on-dark');
            } else {
                evaluateDarkOverlay();
            }
        });

        const closeNav = () => {
            bentoNav!.classList.remove('is-open');
            navToggle!.classList.remove('is-active');
            navToggle!.setAttribute('aria-expanded', 'false');
            document.body.style.overflow = '';
            evaluateDarkOverlay();
            navToggle!.focus();
        };

        navLinks.forEach(link => {
            link.addEventListener('click', closeNav);
        });

        // Escape key closes nav
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && bentoNav!.classList.contains('is-open')) {
                closeNav();
            }
        });

        // Focus trap when nav is open
        bentoNav!.addEventListener('keydown', (e) => {
            if (e.key !== 'Tab' || !bentoNav!.classList.contains('is-open')) return;
            const focusable = [navToggle!, ...bentoNav!.querySelectorAll<HTMLElement>('a[href], button')] as HTMLElement[];
            const first = focusable[0];
            const last = focusable[focusable.length - 1];
            if (e.shiftKey && document.activeElement === first) {
                e.preventDefault();
                last.focus();
            } else if (!e.shiftKey && document.activeElement === last) {
                e.preventDefault();
                first.focus();
            }
        });

        const evaluateDarkOverlay = () => {
            if (bentoNav!.classList.contains('is-open')) return;

            let isOverDark = false;
            document.querySelectorAll('.dark-section').forEach(section => {
                const el = section as HTMLElement;
                const top = el.offsetTop;
                const bottom = top + el.offsetHeight;
                if (window.scrollY > top - 90 && window.scrollY < bottom - 90) {
                    isOverDark = true;
                }
            });

            if (isOverDark) {
                mainHeader!.classList.add('on-dark');
            } else {
                mainHeader!.classList.remove('on-dark');
            }
        };

        window.addEventListener('scroll', evaluateDarkOverlay);
    });
</script>

<style>
    header {
        position: fixed; top: 0; left: 0; width: 100%; height: var(--header-height);
        background: transparent; z-index: 2000; pointer-events: none;
    }

    .header-inner {
        display: flex; justify-content: space-between; align-items: center;
        width: 100%; max-width: 2000px; margin: 0 auto; height: 100%; padding: 0 5vw;
        pointer-events: auto;
    }

    .header-logo {
        display: flex; align-items: center; text-decoration: none;
    }
    .header-logo-img { height: var(--space-8); width: auto; }

    .header-actions {
        display: flex;
        align-items: center;
        gap: var(--space-3);
    }

    .header-login {
        font-family: var(--font-tech);
        font-size: var(--step--1);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-decoration: none;
        color: var(--ink);
        transition: color 0.4s var(--ease-out-expo);
    }
    header.on-dark .header-login {
        color: var(--paper);
    }

    .hamburger {
        background: transparent; border: none;
        cursor: pointer; width: var(--space-6); height: var(--space-6);
        position: relative; z-index: 2100; display: flex; align-items: center; justify-content: flex-end;
    }

    .hamburger-box { width: 24px; height: 8px; position: relative; }

    .hamburger span {
        display: block; position: absolute; height: var(--stroke-weight); width: 100%;
        background: var(--ink); transition: transform 0.4s var(--ease-out-expo), background 0.4s var(--ease-out-expo);
        transform-origin: center;
    }
    header.on-dark .hamburger span { background: var(--paper); }

    .hamburger span:nth-child(1) { top: 0; }
    .hamburger span:nth-child(2) { top: 8px; }

    .hamburger.is-active span:nth-child(1) { transform: translateY(4px) rotate(45deg); background: var(--paper); }
    .hamburger.is-active span:nth-child(2) { transform: translateY(-4px) rotate(-45deg); background: var(--paper); }

    @media (max-width: 768px) {
        .header-logo-img { height: var(--space-6); }
    }
</style>
