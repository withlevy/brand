---
import Badge from './Badge.astro';

interface Props {
    badge?: string;
    title: string;
}

const { badge, title } = Astro.props;
---

<div class="artifact-card">
    {badge && (
        <div style="width: max-content; margin-bottom: var(--space-4);">
            <Badge label={badge} />
        </div>
    )}
    <div class="tech-title" style="margin-bottom: var(--space-2);">{title}</div>
    <slot />
</div>

<style>
    .artifact-card {
        background: var(--paper); width: 100%; padding: var(--space-6);
        border: var(--stroke-weight) solid var(--stroke-color); display: flex; flex-direction: column;
        transition: transform 0.4s var(--ease-out-expo),
                    box-shadow 0.4s var(--ease-out-expo),
                    border-color 0.4s var(--ease-out-expo);
    }

    .artifact-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(15, 12, 41, 0.08);
        border-color: rgba(15, 12, 41, 0.5);
    }

    @media (max-width: 768px) {
        .artifact-card { padding: var(--space-4); }
    }

    @media (prefers-reduced-motion: reduce) {
        .artifact-card:hover { transform: none; }
    }
</style>
