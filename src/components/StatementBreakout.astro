---
interface Props {
    id?: string;
    theme?: 'dark';
    autoHeight?: boolean;
    topNarrative?: string;
    bottomNarrative?: string;
    mainLeft: string;
    mainRightTop: string;
    mainRightBottom: string;
    marginaliaTopLeft?: string;
    marginaliaTopRight?: string;
    marginaliaBottomLeft?: string;
    marginaliaBottomRight?: string;
}

const {
    id,
    theme,
    autoHeight,
    topNarrative,
    bottomNarrative,
    mainLeft,
    mainRightTop,
    mainRightBottom,
    marginaliaTopLeft,
    marginaliaTopRight,
    marginaliaBottomLeft,
    marginaliaBottomRight,
} = Astro.props;

const Tag = theme === 'dark' ? 'footer' : 'section';
const sectionClasses = [
    'void-section',
    theme === 'dark' ? 'dark-section' : '',
    autoHeight ? 'auto-height' : '',
].filter(Boolean).join(' ');
---

<Tag id={id} class={sectionClasses}>
    {marginaliaTopLeft && (
        <div class="marginalia hero-entrance" style="position: absolute; top: 0; left: 5vw; text-align: left; line-height: 1.2; --entrance-order: 0;" set:html={marginaliaTopLeft} />
    )}
    {marginaliaTopRight && (
        <div class="marginalia hero-entrance" style="position: absolute; top: 0; right: 5vw; text-align: right; line-height: 1.2; --entrance-order: 0;" set:html={marginaliaTopRight} />
    )}
    <div class="statement-breakout">
        {topNarrative && <div class="statement-top narrative hero-entrance" style="--entrance-order: 1;" set:html={topNarrative} />}
        <div class="statement-main tech-title">
            <div class="statement-left hero-entrance hero-clip" style="--entrance-order: 2;">
                <span set:html={mainLeft} />
            </div>
            <div class="statement-right hero-entrance hero-clip" style="--entrance-order: 3;">
                <span>{mainRightTop}</span>
                <span>{mainRightBottom}</span>
            </div>
        </div>
        {bottomNarrative && <div class="statement-bottom narrative hero-entrance" style="--entrance-order: 4;" set:html={bottomNarrative} />}
    </div>
    {marginaliaBottomLeft && (
        <div class="marginalia hero-entrance" style="position: absolute; bottom: 0; left: 5vw; text-align: left; line-height: 1.2; --entrance-order: 5;" set:html={marginaliaBottomLeft} />
    )}
    {marginaliaBottomRight && (
        <div class="marginalia hero-entrance" style="position: absolute; bottom: 0; right: 5vw; text-align: right; line-height: 1.2; --entrance-order: 5;" set:html={marginaliaBottomRight} />
    )}
</Tag>

<style>
    .statement-breakout { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; position: relative; overflow: hidden; }
    .statement-top, .statement-bottom { font-family: var(--font-narrative); font-weight: 200; font-variation-settings: "SOFT" 50, "WONK" 0, "opsz" 36; font-size: clamp(1rem, 2.5vw, var(--step-3)); line-height: 1.15; color: var(--ink-light); text-align: center; max-width: 30ch; }
    .statement-top::before, .statement-bottom::before { content: ""; display: table; margin-bottom: calc((1.15 - 0.730) * -0.5em); }
    .statement-main { display: flex; justify-content: center; gap: clamp(0.5rem, 3vw, var(--space-4)); width: 100%; margin: clamp(4.5rem, 12vw, var(--space-18)) 0; font-size: clamp(2rem, 8.5vw, 12rem); line-height: 0.9; letter-spacing: -0.04em; color: var(--ink); }
    .statement-main::before { content: ""; display: table; margin-bottom: calc((0.9 - 0.714) * -0.5em); }
    .statement-left, .statement-right { display: flex; flex-direction: column; white-space: nowrap; }
    .statement-left { text-align: right; justify-content: flex-start; }
    .statement-right { text-align: left; justify-content: flex-start; }

    @media (max-width: 480px) {
        .statement-main { flex-direction: column; align-items: center; }
        .statement-left, .statement-right { text-align: center; }
    }

    :global(.dark-section) .statement-main { color: var(--paper); }
    :global(.dark-section) .statement-top,
    :global(.dark-section) .statement-bottom { color: rgba(245, 245, 243, 0.7); }

    /* Hero entrance choreography */
    .hero-entrance {
        opacity: 0;
        transform: translateY(20px);
        animation: heroReveal 1s var(--ease-out-expo) forwards;
        animation-delay: calc(var(--entrance-order, 0) * 0.15s + 0.3s);
    }

    .hero-clip {
        opacity: 0;
        clip-path: inset(0 0 100% 0);
        animation: heroClipReveal 0.9s var(--ease-out-expo) forwards;
        animation-delay: calc(var(--entrance-order, 0) * 0.15s + 0.3s);
    }

    @keyframes heroReveal {
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes heroClipReveal {
        to { opacity: 1; clip-path: inset(0 0 0% 0); }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-entrance, .hero-clip {
            animation: none !important;
            opacity: 1 !important;
            transform: none !important;
            clip-path: none !important;
        }
    }
</style>
