---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BentoNav from '../components/BentoNav.astro';
import StatementBreakout from '../components/StatementBreakout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Button from '../components/Button.astro';
import { NAV_ITEMS } from '../lib/nav';
---

<BaseLayout title="Work With Us — Levy Studio &amp; Institute" description="The Levy Studio and The Levy Institute.">
    <Header />
    <BentoNav items={NAV_ITEMS} currentPath="/studio" />

    <main id="main-content">
        <h1 class="sr-only">The Levy Studio and Institute</h1>
        <StatementBreakout
            id="cover"
            topNarrative="Beyond the Network."
            mainLeft="WORK&nbsp;:"
            mainRightTop="WITH"
            mainRightBottom="US"
            bottomNarrative="The Levy Studio. The Levy Institute."
        />

        <section id="studio">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">01 // STUDIO</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">THE LEVY STUDIO</h2>
                </div>
                <div class="txt-block reveal">
                    <p class="body-large">The Studio is Levy's co-design practice. For initiatives that need direct strategic design support — navigating institutional systems, building coalitions, developing the architecture that moves serious work through serious terrain.</p>
                </div>
                <div class="txt-block reveal">
                    <p class="body-large">Currently operating The Upskilling Labs with DC Public Library and publishing Human Capital Quarterly — a co-authored report shaped by the coalition it assembles.</p>
                </div>
                <div class="txt-wide reveal" style="margin-top: var(--space-4);">
                    <Button variant="ghost" href="mailto:hello@levy.design" label="Start a conversation" />
                </div>
            </div>
        </section>

        <section id="institute">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">02 // INSTITUTE</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">THE LEVY INSTITUTE</h2>
                </div>
                <div class="txt-block reveal">
                    <p class="body-large">The Institute is Levy's applied research arm. Where the methods are developed, tested, and shared. Where the questions that matter most get the rigor they deserve.</p>
                </div>
                <div class="txt-block reveal">
                    <p class="body-large">Hosts the Builders Breakfast speaker series, produces the strategy essays, and designs the workshop methods Network members use.</p>
                </div>
                <div class="txt-wide reveal" style="margin-top: var(--space-4);">
                    <Button variant="ghost" href="/insights" label="Read our insights" />
                </div>
            </div>
        </section>
    </main>

    <SiteFooter />
</BaseLayout>
