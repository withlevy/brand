---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BentoNav from '../components/BentoNav.astro';
import StatementBreakout from '../components/StatementBreakout.astro';

const navItems = [
    { href: "/#problem",    number: "01", category: "CONTEXT",    title: "THE PROBLEM" },
    { href: "/#model",      number: "02", category: "COMPANY",    title: "THE MODEL", wide: true },
    { href: "/#outcomes",   number: "03", category: "OUTCOMES",   title: "WHAT MEMBERS GET", wide: true },
    { href: "/#who",        number: "04", category: "FIT",        title: "WHO IT'S FOR" },
    { href: "/#membership", number: "05", category: "MEMBERSHIP", title: "THREE WAYS IN" },
];
---

<BaseLayout title="Insights — Levy Strategic Design" description="Essays, analysis, and field-level signal from Levy.">
    <Header />
    <BentoNav items={navItems} />

    <main id="main-content">
        <h1 class="sr-only">Insights from Levy Strategic Design</h1>
        <StatementBreakout
            id="cover"
            topNarrative="Field-level signal."
            mainLeft="INSIGHTS&nbsp;:"
            mainRightTop="FROM"
            mainRightBottom="THE FIELD"
            bottomNarrative="Essays. Analysis. Signal before consensus."
        />

        <section id="insights">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">01 // SIGNAL</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">COMING SOON</h2>
                </div>
                <div class="txt-block reveal">
                    <p class="body-large">Levy's intelligence product — executive essays on how systems work and where the leverage is, field-level signal before it becomes consensus, and curated analysis at the intersection of builders and institutions.</p>
                </div>
                <div class="txt-block reveal">
                    <p class="marginalia">Insider members receive this monthly. The public archive launches soon.</p>
                </div>
            </div>
        </section>
    </main>

    <StatementBreakout
        theme="dark"
        mainLeft="BUILD&nbsp;:"
        mainRightTop="THE"
        mainRightBottom="ROOM"
        marginaliaBottomLeft="LEVY STRATEGIC DESIGN // WASHINGTON, D.C."
        marginaliaBottomRight="EST. 2024"
    />
</BaseLayout>
