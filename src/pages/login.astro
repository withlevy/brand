---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Sign In — Levy Network" description="Sign in to the Levy Network.">
    <Header />

    <main id="main-content">
        <h1 class="sr-only">Sign in to the Levy Network</h1>
        <section id="login" class="void-section">
            <div class="statement-breakout reveal" style="width: 100%; max-width: 480px;">
                <div class="tech-title" style="margin-bottom: var(--space-2); text-align: center;">
                    <span class="display-medium">SIGN IN</span>
                </div>
                <p class="body-medium" style="text-align: center; margin-bottom: var(--space-8); color: var(--ink-muted);">Access your Levy Network membership.</p>

                <!-- Outseta auth embed -->
                <div id="outseta-auth" style="width: 100%; min-height: 300px;">
                    <div data-o-component="Auth" data-o-options='{"widgetMode": "login"}'></div>
                </div>

                <p class="micro-data" style="text-align: center; margin-top: var(--space-8);">
                    Not a member yet? <a href="/join" class="text-link">Explore membership &rarr;</a>
                </p>
            </div>
        </section>
    </main>
</BaseLayout>
