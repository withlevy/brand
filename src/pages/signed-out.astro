---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BentoNav from '../components/BentoNav.astro';
import Button from '../components/Button.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { NAV_ITEMS } from '../lib/nav';
---

<BaseLayout title="Signed Out — Levy Network" description="Your Levy Network session has ended.">
    <Header />
    <BentoNav items={NAV_ITEMS} currentPath="" />

    <main id="main-content">
        <h1 class="sr-only">Signed Out</h1>
        <section class="void-section">
            <div class="statement-breakout reveal" style="width: 100%; max-width: 480px;">
                <div class="tech-title" style="margin-bottom: var(--space-2); text-align: center;">
                    <span class="display-medium">SIGNED OUT</span>
                </div>
                <p class="body-medium" style="text-align: center; margin-bottom: var(--space-8); color: var(--ink-muted);">
                    Your session has ended. The network is still here when you're ready to return.
                </p>
                <div style="display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
                    <Button variant="solid" href="/login" label="Log Back In" />
                    <Button variant="ghost" href="/" label="Return Home" />
                </div>
            </div>
        </section>
    </main>

    <SiteFooter />
</BaseLayout>
