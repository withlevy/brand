---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BentoNav from '../components/BentoNav.astro';
import Button from '../components/Button.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { NAV_ITEMS } from '../lib/nav';
---

<BaseLayout title="Access Denied — Levy Network" description="This page is available to Levy Network members only.">
    <Header />
    <BentoNav items={NAV_ITEMS} currentPath="" />

    <main id="main-content">
        <h1 class="sr-only">Access Denied</h1>
        <section class="void-section">
            <div class="statement-breakout reveal" style="width: 100%; max-width: 480px;">
                <div class="tech-title" style="margin-bottom: var(--space-2); text-align: center;">
                    <span class="display-medium">MEMBERS ONLY</span>
                </div>
                <p class="body-medium" id="access-message" style="text-align: center; margin-bottom: var(--space-8); color: var(--ink-muted);">This page is available to Levy Network members. Sign in to access your dashboard, or explore membership options.</p>

                <!-- Default: not logged in — Outseta hides when authenticated -->
                <div id="cta-logged-out" data-o-anonymous="1" style="display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
                    <Button variant="solid" href="/login" label="Sign In" />
                    <Button variant="ghost" href="/join" label="Explore Membership" />
                </div>

                <!-- Logged in but wrong tier — Outseta shows when authenticated -->
                <div id="cta-logged-in" data-o-authenticated="1" style="display: none; flex-direction: column; align-items: center; gap: var(--space-3);">
                    <div style="display: flex; gap: var(--space-3); flex-wrap: wrap; justify-content: center;">
                        <Button variant="solid" href="/join" label="Upgrade Membership" />
                        <Button variant="ghost" href="/dashboard" label="Go to Dashboard" />
                    </div>
                </div>
            </div>
        </section>
    </main>

    <SiteFooter />
</BaseLayout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Outseta nocode attributes handle CTA visibility via data-o-anonymous / data-o-authenticated.
        // This script only updates the message text for authenticated users.
        let attempts = 0;
        const check = async () => {
            const Outseta = (window as any).Outseta;
            if (Outseta?.getUser) {
                try {
                    const user = await Outseta.getUser();
                    if (user?.Email) {
                        const message = document.getElementById('access-message');
                        if (message) {
                            message.textContent = 'Your current membership tier doesn\u2019t include access to this page. Upgrade to unlock more of the Levy Network.';
                        }
                    }
                } catch {}
            } else if (++attempts < 20) {
                setTimeout(check, 500);
            }
        };
        check();
    });
</script>
