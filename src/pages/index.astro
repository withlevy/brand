---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BentoNav from '../components/BentoNav.astro';
import StatementBreakout from '../components/StatementBreakout.astro';
import ArtifactCard from '../components/ArtifactCard.astro';
import Button from '../components/Button.astro';

const navItems = [
    { href: "#company",    number: "01", category: "COMPANY",    title: "WHO WE ARE" },
    { href: "#work",       number: "02", category: "PROOF",      title: "WORK IN THE FIELD", wide: true },
    { href: "#network",    number: "03", category: "NETWORK",    title: "THE LEVY NETWORK", wide: true },
    { href: "#membership", number: "04", category: "MEMBERSHIP", title: "THREE WAYS IN" },
    { href: "#join",       number: "05", category: "ACTION",     title: "JOIN" },
];
---

<BaseLayout title="Levy Strategic Design" description="For people operating ahead of consensus.">
    <Header />
    <BentoNav items={navItems} />

    <main id="main-content">

        <!-- ============================================================
             SECTION 1 — HERO
             ============================================================ -->
        <StatementBreakout
            id="cover"
            marginaliaTopLeft="WASHINGTON<br>DISTRICT OF COLUMBIA<br>EST. 2024"
            marginaliaTopRight="LEVY STRATEGIC DESIGN<br>THE LEVY NETWORK<br>THE LEVY STUDIO<br>THE LEVY INSTITUTE"
            topNarrative="For people operating ahead of consensus."
            mainLeft="MISSION&nbsp;:"
            mainRightTop="OUTLIER"
            mainRightBottom="OUTCOMES"
            bottomNarrative="Levy Strategic Design<br>Washington<br>District <span class='of-fraunces'>of</span> Columbia"
        />

        <!-- ============================================================
             SECTION 2 — PORTRAITS
             ============================================================ -->
        <section id="problem">
            <div class="layout-grid">
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">THE WORK DESERVES BETTER INFRASTRUCTURE</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="narrative">Not because you're not capable. Because the systems weren't built for what you're trying to do.</p>
                </div>

                <div class="txt-block">
                    <p class="body-large reveal" style="margin-bottom: var(--space-4);">The founder who can see exactly how her company changes a market — structurally, not incrementally — and keeps hitting institutional terrain nobody taught her to navigate.</p>
                    <p class="body-large reveal" style="margin-bottom: var(--space-4); transition-delay: 0.1s;">The program officer with a clearer view than almost anyone of what would actually work. No private partners who know how to move within the constraints he lives inside every day.</p>
                    <p class="body-large reveal" style="margin-bottom: var(--space-4); transition-delay: 0.2s;">The department head who knows his institution has the infrastructure, the legitimacy, and the relationships to anchor something significant. Still looking for people who know how to build for those assets rather than around them.</p>
                    <p class="body-large reveal" style="transition-delay: 0.3s;">The corporate strategist who has identified the move. Realizing the internal case will never get made without external architecture. Nobody taught her how to build it.</p>
                </div>

                <div class="txt-block reveal">
                    <p class="tech-title display-medium">LEVY IS WHERE THOSE PEOPLE FIND EACH OTHER.</p>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 3 — THREE ARMS
             ============================================================ -->
        <section id="company">
            <div class="layout-grid">
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">ONE COMPANY. THREE FUNCTIONS.</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="narrative">A network for operating in serious company. A studio for building what the work requires. An institute for developing the methods.</p>
                </div>

                <div class="split-3up reveal">
                    <ArtifactCard badge="COMMUNITY" title="THE LEVY NETWORK">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">The membership community. Events, signal, curated introductions, and the rooms where the work actually moves.</p>
                        <div style="margin-top: auto;">
                            <Button variant="ghost" href="#membership" label="See membership" />
                        </div>
                    </ArtifactCard>

                    <ArtifactCard badge="CO-DESIGN" title="THE LEVY STUDIO">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">The practice arm. Direct strategic design for initiatives navigating institutional systems. Currently operating The Upskilling Labs and publishing Human Capital Quarterly.</p>
                        <div style="margin-top: auto;">
                            <Button variant="ghost" href="#work" label="See current work" />
                        </div>
                    </ArtifactCard>

                    <ArtifactCard badge="RESEARCH" title="THE LEVY INSTITUTE">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">The intellectual engine. Hosts the Builders Breakfast speaker series, produces the strategy essays, and designs the workshop methods Network members use.</p>
                        <div style="margin-top: auto;">
                            <Button variant="ghost" href="/studio#institute" label="Learn more" />
                        </div>
                    </ArtifactCard>
                </div>

                <div class="txt-wide reveal" style="margin-top: var(--space-4);">
                    <p class="marginalia">The arms are distinct but not separate. The Institute designs the methods. The Studio builds the interventions. The Network is where the people find each other.</p>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 4 — STUDIO PROOF
             ============================================================ -->
        <section id="work">
            <div class="layout-grid">
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">ALREADY IN THE FIELD</h2>
                </div>

                <div class="split-2up reveal">
                    <div class="split-l">
                        <ArtifactCard badge="LEVY STUDIO" title="THE UPSKILLING LABS">
                            <p class="body-medium" style="margin-bottom: var(--space-4);">A workforce development initiative building the bridge between institutional employers and the people they need to reach. Designing upskilling infrastructure that works within the systems public and private organizations actually operate.</p>
                            <p class="micro-data" style="margin-top: auto;">ACTIVE // WASHINGTON, D.C.</p>
                        </ArtifactCard>
                    </div>
                    <div class="split-r">
                        <ArtifactCard badge="LEVY STUDIO" title="HUMAN CAPITAL QUARTERLY">
                            <p class="body-medium" style="margin-bottom: var(--space-4);">A quarterly event series hosted in Washington, D.C., convening public and private workforce-focused organizations. Becoming a co-authored report and publication by the coalition it assembles.</p>
                            <p class="micro-data" style="margin-top: auto;">QUARTERLY // WASHINGTON, D.C.</p>
                        </ArtifactCard>
                    </div>
                </div>

                <div class="txt-block reveal" style="margin-top: var(--space-4);">
                    <p class="marginalia">Network members have early access to Studio initiatives and shape what comes next.</p>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 5 — GEAR-SHIFT
             ============================================================ -->
        <StatementBreakout
            theme="dark"
            autoHeight
            id="shift"
            topNarrative="The mix is the method."
            mainLeft="BUILD&nbsp;:"
            mainRightTop="THE"
            mainRightBottom="ROOM."
            bottomNarrative="60% founders and builders. 30% institutional operators and public servants. 10% researchers. Each group has what the other two cannot get anywhere else."
        />

        <!-- ============================================================
             SECTION 6 — NETWORK EXPERIENCE
             ============================================================ -->
        <section id="network">
            <div class="layout-grid">
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">WHAT BECOMES POSSIBLE</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="narrative">Not the same people. The same calibration.</p>
                </div>

                <div class="txt-block">
                    <p class="body-large reveal">A Tuesday morning breakfast where a federal program officer and a startup founder compare notes on the same procurement process from opposite sides — and neither of them expected to leave with what they left with. A member trying to get closer to a major technology company who pulls a thread through the Network and finds the person who ran civic hackathons with that company in another city. By the end of the week they have an introduction they couldn't have manufactured.</p>
                    <p class="body-large reveal" style="margin-top: var(--space-4); transition-delay: 0.1s;">What compounds over time isn't just relationships or access. It's fluency — the ability to read a system, find the leverage, build the coalition, and move something significant through institutions that weren't designed to move quickly. The Network is built to make that something you develop deliberately, in good company.</p>
                </div>

                <div class="txt-block reveal" style="margin-top: var(--space-8);">
                    <dl style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-1) var(--space-8); font-family: var(--font-tech); font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.05em;">
                        <dt style="color: var(--ink); font-weight: 500;">Builders Breakfasts</dt>
                        <dd style="color: var(--ink-muted); font-weight: 300;">Monthly</dd>
                        <dt style="color: var(--ink); font-weight: 500;">Strategy Sprints</dt>
                        <dd style="color: var(--ink-muted); font-weight: 300;">Ongoing</dd>
                        <dt style="color: var(--ink); font-weight: 500;">Human Capital Quarterly</dt>
                        <dd style="color: var(--ink-muted); font-weight: 300;">Quarterly</dd>
                        <dt style="color: var(--ink); font-weight: 500;">Member Happy Hours</dt>
                        <dd style="color: var(--ink-muted); font-weight: 300;">Monthly</dd>
                        <dt style="color: var(--ink); font-weight: 500;">Portfolio Initiatives</dt>
                        <dd style="color: var(--ink-muted); font-weight: 300;">Active</dd>
                    </dl>
                </div>

                <div class="txt-wide reveal" style="margin-top: var(--space-8); display: flex; gap: var(--space-8); flex-wrap: wrap; font-family: var(--font-tech); font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-muted);">
                    <span>FOUNDING COHORT</span>
                    <span>WASHINGTON, D.C.</span>
                    <span>60 / 30 / 10</span>
                    <span>EST. 2024</span>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 7 — MEMBERSHIP TIERS
             ============================================================ -->
        <section id="membership">
            <div class="layout-grid">
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">THREE WAYS IN</h2>
                </div>

                <div class="txt-wide reveal">
                    <p class="marginalia">Each tier is a distinct relationship with Levy — not a volume discount on the same product.</p>
                </div>

                <div class="split-3up reveal">
                    <ArtifactCard badge="SIGNAL TIER" title="INSIDER">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">You're building orientation — field-level understanding of how the systems you're working in actually operate.</p>
                        <div class="body-small" style="margin-bottom: var(--space-4);">
                            <p style="margin-bottom: var(--space-1);">Monthly intelligence briefing</p>
                            <p style="margin-bottom: var(--space-1);">Executive essays on systems and leverage</p>
                            <p style="margin-bottom: var(--space-1);">Curated co-authorship (occasional)</p>
                            <p>Content designed to forward</p>
                        </div>
                        <p class="tech-title display-medium" style="margin-top: auto;">$XX / MO</p>
                        <div style="margin-top: var(--space-4);">
                            <Button variant="ghost" href="#" label="Join as Insider" />
                        </div>
                    </ArtifactCard>

                    <ArtifactCard badge="CORE TIER" title="BUILDER">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">You're developing the capability — in contact with people navigating the same systems from different positions.</p>
                        <div class="body-small" style="margin-bottom: var(--space-4);">
                            <p style="margin-bottom: var(--space-1);">Everything in Insider</p>
                            <p style="margin-bottom: var(--space-1);">Builders Breakfasts (monthly, small, mixed)</p>
                            <p style="margin-bottom: var(--space-1);">Strategy Sprints and workshops</p>
                            <p style="margin-bottom: var(--space-1);">Full network access and curated introductions</p>
                            <p style="margin-bottom: var(--space-1);">Member happy hours</p>
                            <p>Portfolio initiative participation</p>
                        </div>
                        <p class="tech-title display-medium" style="margin-top: auto;">$XX / MO</p>
                        <div style="margin-top: var(--space-4);">
                            <Button variant="solid" href="#" label="Join as Builder" />
                        </div>
                    </ArtifactCard>

                    <ArtifactCard badge="CO-DESIGN TIER" title="ARCHITECT">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">You have a real initiative and you need Levy working directly alongside you on the systems it needs to move through.</p>
                        <div class="body-small" style="margin-bottom: var(--space-4);">
                            <p style="margin-bottom: var(--space-1);">Everything in Builder</p>
                            <p style="margin-bottom: var(--space-1);">Direct advisory access, Levy senior team</p>
                            <p style="margin-bottom: var(--space-1);">Structured co-design sessions</p>
                            <p>Studio pathway for qualifying initiatives</p>
                        </div>
                        <p class="body-small" style="margin-top: auto;">Architect is by conversation. <a href="#contact" class="text-link">Get in touch →</a></p>
                    </ArtifactCard>
                </div>

                <div class="txt-wide reveal" style="margin-top: var(--space-4);">
                    <p class="marginalia">The people are interesting. The work is genuinely more interesting than almost anywhere else you'll spend your Tuesday mornings.</p>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 8 — ACTION
             ============================================================ -->
        <section id="join">
            <div class="layout-grid">
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">JOIN THE LEVY NETWORK</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="body-large">The founding cohort is open. Insider and Builder are self-serve. Architect starts with a conversation.</p>
                </div>

                <div class="txt-wide reveal" style="display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap; margin-top: var(--space-6);">
                    <Button variant="ghost" href="#" label="Join as Insider" />
                    <Button variant="solid" href="#" label="Join as Builder" />
                    <a href="#contact" class="text-link" style="font-family: var(--font-tech); font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.1em;">Apply for Architect →</a>
                </div>

                <div class="txt-wide reveal" style="margin-top: var(--space-8); opacity: 0.5;">
                    <p class="micro-data">LEVY STRATEGIC DESIGN // WASHINGTON, D.C. // EST. 2024</p>
                </div>
            </div>
        </section>

    </main>

    <!-- ============================================================
         FOOTER
         ============================================================ -->
    <StatementBreakout
        theme="dark"
        topNarrative="The founding cohort is open. The work is worth doing."
        mainLeft="BUILD&nbsp;:"
        mainRightTop="THE"
        mainRightBottom="ROOM"
        marginaliaBottomLeft="LEVY STRATEGIC DESIGN // WASHINGTON, D.C."
        marginaliaBottomRight="EST. 2024"
    />

</BaseLayout>
