---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BentoNav from '../components/BentoNav.astro';
import StatementBreakout from '../components/StatementBreakout.astro';
import ArtifactCard from '../components/ArtifactCard.astro';
import Button from '../components/Button.astro';
import AccordionWrapper from '../components/AccordionWrapper.astro';
import Accordion from '../components/Accordion.astro';

const navItems = [
    { href: "#problem",    number: "01", category: "CONTEXT",    title: "THE PROBLEM" },
    { href: "#model",      number: "02", category: "COMPANY",    title: "THE MODEL", wide: true },
    { href: "#outcomes",   number: "03", category: "OUTCOMES",   title: "WHAT MEMBERS GET", wide: true },
    { href: "#who",        number: "04", category: "FIT",        title: "WHO IT'S FOR" },
    { href: "#membership", number: "05", category: "MEMBERSHIP", title: "THREE WAYS IN" },
];

const OUTSETA_BUILDER = "https://levy.outseta.com/auth?widgetMode=register&planUid=rmk5w09g#o-anonymous";
const OUTSETA_INSIDER = "https://levy.outseta.com/auth?widgetMode=register&planUid=Nmdndw90#o-anonymous";
---

<BaseLayout title="The Levy Network" description="The membership network for people operating ahead of consensus.">
    <Header />
    <BentoNav items={navItems} />

    <main id="main-content">
        <h1 class="sr-only">Levy Strategic Design — Outlier Outcomes</h1>

        <!-- ============================================================
             SECTION 1 — HERO
             ============================================================ -->
        <StatementBreakout
            id="cover"
            marginaliaTopLeft="WASHINGTON, D.C."
            marginaliaTopRight="EST. 2024"
            topNarrative="For people operating ahead of consensus."
            mainLeft="MISSION&nbsp;:"
            mainRightTop="OUTLIER"
            mainRightBottom="OUTCOMES"
            bottomNarrative="Network &middot; Studio &middot; Institute"
        />

        <div class="hero-cta-bar">
            <Button variant="solid" href={OUTSETA_BUILDER} label="Join as Builder" />
            <Button variant="ghost" href={OUTSETA_INSIDER} label="Join as Insider" />
        </div>

        <!-- ============================================================
             SECTION 2 — PROBLEM
             ============================================================ -->
        <section id="problem">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">01 // Context</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">THE WORK DESERVES BETTER INFRASTRUCTURE</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="narrative">Not because you're not capable. Because the systems weren't built for what you're trying to do.</p>
                </div>

                <div class="split-3up reveal">
                    <div>
                        <p class="micro-data" style="margin-bottom: var(--space-2);">The Founder</p>
                        <p class="body-large">You can see exactly how your company changes a market — structurally, not incrementally. You keep hitting institutional terrain nobody taught you to navigate. Procurement, regulation, public-sector partnerships. The map doesn't exist yet.</p>
                    </div>
                    <div>
                        <p class="micro-data" style="margin-bottom: var(--space-2);">The Public Servant</p>
                        <p class="body-large">You have a clearer view than almost anyone of what would actually work. You don't have private partners who understand the constraints you live inside every day. The outside signal you need doesn't arrive through official channels.</p>
                    </div>
                    <div>
                        <p class="micro-data" style="margin-bottom: var(--space-2);">The Researcher</p>
                        <p class="body-large">Your work matters in theory. You're still looking for the people and the rooms where it starts to matter in practice — where methods become interventions and papers become leverage.</p>
                    </div>
                </div>

                <div class="txt-block reveal">
                    <p class="tech-title display-medium">LEVY IS WHERE THOSE PEOPLE FIND EACH OTHER.</p>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 3 — THE MODEL
             ============================================================ -->
        <section id="model">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">02 // Company</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">ONE COMPANY. THREE FUNCTIONS.</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="narrative">A network where you operate in serious company. A studio that builds what your work requires. An institute that develops the methods.</p>
                </div>

                <div class="split-3up reveal">
                    <ArtifactCard badge="NETWORK" title="THE LEVY NETWORK">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">Where the collision happens. Events, curated introductions, and the rooms where the work actually moves. The people are interesting. The work is more interesting.</p>
                        <div style="margin-top: auto;">
                            <Button variant="ghost" href="#membership" label="See membership" />
                        </div>
                    </ArtifactCard>

                    <ArtifactCard badge="STUDIO" title="THE LEVY STUDIO">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">Where the work gets pressure-tested in the field. Direct strategic design for initiatives navigating institutional systems. Currently operating The Upskilling Labs and publishing Human Capital Quarterly.</p>
                        <div style="margin-top: auto;">
                            <Button variant="ghost" href="#proof" label="See current work" />
                        </div>
                    </ArtifactCard>

                    <ArtifactCard badge="INSTITUTE" title="THE LEVY INSTITUTE">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">Where the methods are developed and the field-shaping ideas live. Hosts the Builders Breakfast speaker series, produces the strategy essays, and designs the workshop methods Network members use.</p>
                        <div style="margin-top: auto;">
                            <Button variant="ghost" href="/studio#institute" label="Learn more" />
                        </div>
                    </ArtifactCard>
                </div>

                <div class="txt-wide reveal" style="margin-top: var(--space-4);">
                    <p class="marginalia">The Institute designs the methods. The Studio tests them in the field. The Network is where the people find each other. Each arm feeds the others.</p>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 4 — WHAT MEMBERS GET
             ============================================================ -->
        <section id="outcomes">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">03 // Outcomes</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">WHAT MEMBERS GET</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="narrative">Not a feature list. A shift in how you operate.</p>
                </div>

                <div class="split-3up reveal">
                    <ArtifactCard badge="INSIDER" title="FIELD-LEVEL ORIENTATION">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">You develop a persistent read on the systems you're working in. The monthly intelligence briefing gives you what internal channels don't. The executive essays give you the strategic frame. Content designed to forward — to the colleague, the board member, the partner who needs to see what you see.</p>
                        <div class="body-small" style="margin-bottom: var(--space-4);">
                            <p style="margin-bottom: var(--space-1);">Monthly intelligence briefing</p>
                            <p style="margin-bottom: var(--space-1);">Executive essays on systems and leverage</p>
                            <p>Curated co-authorship opportunities</p>
                        </div>
                    </ArtifactCard>

                    <ArtifactCard badge="BUILDER ADDS" title="CAPABILITY AND COMPANY">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">You build fluency — the ability to read a system, find the leverage, build the coalition, and move something significant. You do this in contact with people navigating the same terrain from different positions. That compounds.</p>
                        <div class="body-small" style="margin-bottom: var(--space-4);">
                            <p style="margin-bottom: var(--space-1);">Builders Breakfasts — monthly, small, mixed</p>
                            <p style="margin-bottom: var(--space-1);">Strategy Sprints and workshops</p>
                            <p style="margin-bottom: var(--space-1);">Full network access and curated introductions</p>
                            <p style="margin-bottom: var(--space-1);">Member happy hours</p>
                            <p>Portfolio initiative participation</p>
                        </div>
                    </ArtifactCard>

                    <ArtifactCard badge="ARCHITECT ADDS" title="LEVY WORKING ALONGSIDE YOU">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">You have a real initiative. You need strategic design capacity embedded in your work — not advice from the outside, but Levy operating directly alongside you on the systems your initiative needs to move through.</p>
                        <div class="body-small" style="margin-bottom: var(--space-4);">
                            <p style="margin-bottom: var(--space-1);">Direct advisory access, Levy senior team</p>
                            <p style="margin-bottom: var(--space-1);">Structured co-design sessions</p>
                            <p>Studio pathway for qualifying initiatives</p>
                        </div>
                    </ArtifactCard>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 5 — PROOF
             ============================================================ -->
        <section id="proof">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">04 // Proof</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">ALREADY IN THE FIELD</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="narrative">Live Studio work generating the signal, methods, and credibility that flow back into the Network.</p>
                </div>

                <div class="split-2up reveal">
                    <div class="split-l">
                        <ArtifactCard badge="LEVY STUDIO" title="THE UPSKILLING LABS">
                            <p class="body-medium" style="margin-bottom: var(--space-4);">An AI upskilling cohort built with DC Public Library — designing workforce development infrastructure that works within the systems public and private organizations actually operate. The methods developed here become Network workshop content. The relationships built here become Network introductions.</p>
                            <p class="micro-data" style="margin-top: auto;">ACTIVE // WASHINGTON, D.C.</p>
                        </ArtifactCard>
                    </div>
                    <div class="split-r">
                        <ArtifactCard badge="LEVY STUDIO" title="HUMAN CAPITAL QUARTERLY">
                            <p class="body-medium" style="margin-bottom: var(--space-4);">A quarterly convening of public and private workforce-focused organizations in Washington, D.C. Becoming a co-authored report and publication by the coalition it assembles. Network members get early access and shape the agenda.</p>
                            <p class="micro-data" style="margin-top: auto;">QUARTERLY // WASHINGTON, D.C.</p>
                        </ArtifactCard>
                    </div>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 6 — WHO IT'S FOR
             ============================================================ -->
        <section id="who">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">05 // Fit</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">WHO IT'S FOR</h2>
                </div>

                <div class="split-3up reveal">
                    <ArtifactCard badge="FOUNDERS & BUILDERS" title="YOU NEED THE INSTITUTIONAL MAP">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">You're building something that touches public systems, regulated industries, or institutional buyers. You can see the structural opportunity. You keep hitting terrain nobody taught you to navigate.</p>
                        <p class="body-small" style="margin-bottom: var(--space-2);"><strong>Core fear:</strong> Building something significant and getting locked out by systems you don't know how to move through.</p>
                        <p class="body-small"><strong>Outlier outcome:</strong> You become the person institutions call — because you learned to build for their constraints, not around them.</p>
                    </ArtifactCard>

                    <ArtifactCard badge="INSTITUTIONAL OPERATORS" title="YOU NEED OUTSIDE SIGNAL">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">You work inside government, a university, a hospital system, a foundation. You know the internal briefings aren't enough. The fields you operate in move faster than your institution's ability to track them.</p>
                        <p class="body-small" style="margin-bottom: var(--space-2);"><strong>Core fear:</strong> Your institution has the infrastructure to anchor something significant, and you can't find the external partners who know how to build for it.</p>
                        <p class="body-small"><strong>Outlier outcome:</strong> You lead the initiative others follow — because you had the outside architecture before the internal case was ready.</p>
                    </ArtifactCard>

                    <ArtifactCard badge="RESEARCHERS & PRACTITIONERS" title="YOU NEED PRACTICAL APPLICATION">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">Your work matters. You've identified the move. You're realizing the case will never get made without external architecture — the people, the rooms, the pressure-testing that turns research into leverage.</p>
                        <p class="body-small" style="margin-bottom: var(--space-2);"><strong>Core fear:</strong> Producing work that's cited but never implemented. Relevance in theory, irrelevance in practice.</p>
                        <p class="body-small"><strong>Outlier outcome:</strong> You shape the field — not just study it. Your methods become the ones practitioners actually use.</p>
                    </ArtifactCard>
                </div>

                <div class="txt-wide reveal" style="margin-top: var(--space-4); display: flex; justify-content: center;">
                    <Button variant="solid" href={OUTSETA_BUILDER} label="Join as Builder" />
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 7 — MEMBERSHIP TIERS
             ============================================================ -->
        <section id="membership">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">06 // Membership</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">THREE WAYS IN</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="narrative">Each tier is a distinct relationship with Levy — not a volume discount on the same product.</p>
                </div>

                <div class="split-3up reveal">
                    <ArtifactCard badge="SIGNAL TIER" title="INSIDER">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">The signal tier. You're building orientation — field-level understanding of how the systems you're working in actually operate. Some of the most effective members here are institutional operators using Insider intelligence to stay ahead of fields that move faster than their internal briefings.</p>
                        <div class="body-small" style="margin-bottom: var(--space-4);">
                            <p style="margin-bottom: var(--space-1);">Monthly intelligence briefing</p>
                            <p style="margin-bottom: var(--space-1);">Executive essays on systems and leverage</p>
                            <p style="margin-bottom: var(--space-1);">Curated co-authorship (occasional)</p>
                            <p>Content designed to forward</p>
                        </div>
                        <!-- PRICING: confirm with Outseta -->
                        <p class="tech-title display-medium" style="margin-top: auto;">$XX / MO</p>
                        <div style="margin-top: var(--space-4);">
                            <Button variant="ghost" href={OUTSETA_INSIDER} label="Join as Insider" />
                        </div>
                    </ArtifactCard>

                    <div class="tier-recommended">
                        <ArtifactCard badge="CORE TIER — RECOMMENDED" title="BUILDER">
                            <p class="body-medium" style="margin-bottom: var(--space-4);">The center of gravity of the Network. You're developing the capability — in contact with people navigating the same systems from different positions. The mix is the method: founders, operators, researchers, each with what the other two cannot get anywhere else.</p>
                            <div class="body-small" style="margin-bottom: var(--space-4);">
                                <p style="margin-bottom: var(--space-1);">Everything in Insider</p>
                                <p style="margin-bottom: var(--space-1);">Builders Breakfasts — monthly, small, mixed</p>
                                <p style="margin-bottom: var(--space-1);">Strategy Sprints and workshops</p>
                                <p style="margin-bottom: var(--space-1);">Full network access and curated introductions</p>
                                <p style="margin-bottom: var(--space-1);">Member happy hours</p>
                                <p>Portfolio initiative participation</p>
                            </div>
                            <!-- PRICING: confirm with Outseta -->
                            <p class="tech-title display-medium" style="margin-top: auto;">$XX / MO</p>
                            <div style="margin-top: var(--space-4);">
                                <Button variant="solid" href={OUTSETA_BUILDER} label="Join as Builder" />
                            </div>
                        </ArtifactCard>
                    </div>

                    <ArtifactCard badge="CO-DESIGN TIER" title="ARCHITECT">
                        <p class="body-medium" style="margin-bottom: var(--space-4);">Not purchasable. You have a real initiative and you need Levy working directly alongside you on the systems it needs to move through. Architect is by conversation — if you're working on something that warrants it, we'll know quickly.</p>
                        <div class="body-small" style="margin-bottom: var(--space-4);">
                            <p style="margin-bottom: var(--space-1);">Everything in Builder</p>
                            <p style="margin-bottom: var(--space-1);">Direct advisory access, Levy senior team</p>
                            <p style="margin-bottom: var(--space-1);">Structured co-design sessions</p>
                            <p>Studio pathway for qualifying initiatives</p>
                        </div>
                        <p class="body-small" style="margin-top: auto;"><a href="mailto:hello@levy.design" class="text-link">Start a conversation &rarr;</a></p>
                    </ArtifactCard>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 8 — FOUNDING MEMBER FRAME
             ============================================================ -->
        <section id="founding" class="dark-section">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">07 // Founding Cohort</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">THE FOUNDING COHORT IS OPEN</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="body-large">The Levy Network is in its founding phase. The people joining now are not early adopters of a finished product. They are shaping it — establishing the culture, the norms, the caliber of conversation, and the standard for what this network becomes.</p>
                </div>

                <div class="txt-block reveal">
                    <p class="body-large">That is worth something later membership cannot replicate. The founding cohort doesn't just get access. It gets authorship.</p>
                </div>

                <div class="txt-wide reveal" style="margin-top: var(--space-4); display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap;">
                    <Button variant="solid" href={OUTSETA_BUILDER} label="Join as Builder" />
                    <Button variant="ghost" href={OUTSETA_INSIDER} label="Join as Insider" />
                </div>

                <div class="txt-wide reveal" style="margin-top: var(--space-4);">
                    <p class="micro-data">WASHINGTON, D.C. // EST. 2024 // FOUNDING PHASE</p>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 9 — OBJECTIONS
             ============================================================ -->
        <section id="objections">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">08 // Questions</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">QUESTIONS YOU SHOULD ASK</h2>
                </div>

                <div class="txt-wide reveal">
                    <AccordionWrapper>
                        <Accordion title="Is this just networking?" id="obj-1">
                            <p class="body-medium">No. Networking is transactional — you show up hoping to meet the right person. Levy is architectural. The Network is built around a specific thesis: that founders, institutional operators, and researchers each hold leverage the other two need. The events, introductions, and programming are designed to make that leverage usable. The Studio and Institute generate the work that makes the Network worth being in.</p>
                        </Accordion>
                        <Accordion title="Is this only for people in DC?" id="obj-2">
                            <p class="body-medium">Levy is based in Washington, D.C. and most in-person programming happens here. But the Network's value isn't geographic — it's structural. If you're building at the intersection of institutions, markets, and public systems, the signal and relationships are relevant regardless of where you sit. Insider membership is fully remote. Builder events are concentrated in D.C. with select programming elsewhere.</p>
                        </Accordion>
                        <Accordion title="What's the difference between Insider and Builder?" id="obj-3">
                            <p class="body-medium">Insider is the signal tier — intelligence, essays, and orientation. You develop a persistent read on the systems you're working in. Builder is the relationship tier — you're in the room, building fluency alongside people navigating the same terrain. Different commitment, different relationship. Not a discount version of the same thing.</p>
                        </Accordion>
                        <Accordion title="Why pay for this?" id="obj-4">
                            <p class="body-medium">Because the alternative is more expensive. You spend months finding the right introduction, navigating procurement blind, or building a coalition by trial and error. Levy compresses that. The intelligence saves you from misreading the field. The network saves you from building alone. The Studio work proves the methods before you need them. Membership is the cheapest version of what Levy provides.</p>
                        </Accordion>
                        <Accordion title="How selective is Architect?" id="obj-5">
                            <p class="body-medium">Architect is not a purchase — it's a conversation. If you have a real initiative that would benefit from Levy's direct strategic design capacity, start with a conversation. If it's a fit, we'll know quickly. If it's not, Builder gives you everything else.</p>
                        </Accordion>
                        <Accordion title="How does Studio work benefit members?" id="obj-6">
                            <p class="body-medium">Every Studio engagement generates methods, relationships, and signal that flow back into the Network. The Upskilling Labs develop workshop content that Builder members use. Human Capital Quarterly creates the convenings where Network connections form. Studio work is not separate from the Network — it's the engine that makes the Network's content and credibility real.</p>
                        </Accordion>
                    </AccordionWrapper>
                </div>
            </div>
        </section>

        <!-- ============================================================
             SECTION 10 — FINAL CTA
             ============================================================ -->
        <section id="join">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">09 // Join</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">JOIN THE LEVY NETWORK</h2>
                </div>

                <div class="txt-block reveal">
                    <p class="body-large">The founding cohort is open. The work is worth doing. The room is worth building.</p>
                </div>

                <div class="txt-wide reveal" style="display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap; margin-top: var(--space-6);">
                    <Button variant="solid" href={OUTSETA_BUILDER} label="Join as Builder" />
                    <Button variant="ghost" href={OUTSETA_INSIDER} label="Join as Insider" />
                    <a href="mailto:hello@levy.design" class="text-link" style="font-family: var(--font-tech); font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.1em;">Start a conversation about Architect &rarr;</a>
                </div>
            </div>
        </section>

    </main>

    <!-- ============================================================
         FOOTER
         ============================================================ -->
    <StatementBreakout
        theme="dark"
        topNarrative="The founding cohort is open."
        mainLeft="BUILD&nbsp;:"
        mainRightTop="THE"
        mainRightBottom="ROOM"
        marginaliaBottomLeft="LEVY STRATEGIC DESIGN"
        marginaliaBottomRight="WASHINGTON, D.C."
    />

</BaseLayout>

<style>
    .hero-cta-bar {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: var(--space-4);
        padding: var(--space-8) 5vw;
        border-bottom: var(--stroke-weight) solid var(--stroke-color);
    }

    .tier-recommended {
        border: 2px solid var(--ink);
        position: relative;
    }
    .tier-recommended :global(.artifact-card) {
        border: none;
    }

    /* Dark section button overrides */
    .dark-section :global(.btn) {
        border-color: var(--paper);
        color: var(--paper);
    }
    .dark-section :global(.btn:hover) {
        background: var(--paper);
        color: var(--ink);
    }
    .dark-section :global(.btn-solid) {
        background: var(--paper);
        color: var(--ink);
    }
    .dark-section :global(.btn-solid:hover) {
        background: transparent;
        color: var(--paper);
    }

    @media (max-width: 480px) {
        .hero-cta-bar {
            flex-direction: column;
            padding: var(--space-6) 4vw;
        }
    }
</style>
