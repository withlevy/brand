---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BentoNav from '../components/BentoNav.astro';
import Button from '../components/Button.astro';
import Badge from '../components/Badge.astro';
import FormInput from '../components/FormInput.astro';
import FormTextarea from '../components/FormTextarea.astro';
import FormSelect from '../components/FormSelect.astro';
import FormCheckbox from '../components/FormCheckbox.astro';
import FormRadio from '../components/FormRadio.astro';
import MediaPlaceholder from '../components/MediaPlaceholder.astro';
import AccordionWrapper from '../components/AccordionWrapper.astro';
import Accordion from '../components/Accordion.astro';
import ArtifactCard from '../components/ArtifactCard.astro';
import DoDontBox from '../components/DoDontBox.astro';
import SystemTable from '../components/SystemTable.astro';
import Blockquote from '../components/Blockquote.astro';

const navItems = [
    { href: "#typography", number: "01", category: "STYLE", title: "TYPOGRAPHY" },
    { href: "#buttons", number: "02", category: "INTERACTION", title: "BUTTONS & LINKS" },
    { href: "#forms", number: "03", category: "INPUT", title: "FORM CONTROLS", wide: true },
    { href: "#media", number: "04", category: "IMAGERY", title: "MEDIA & RATIOS", wide: true },
    { href: "#accordions", number: "05", category: "TOGGLES", title: "ACCORDIONS" },
    { href: "#data", number: "06", category: "STRUCTURE", title: "TABLES & DATA" },
    { href: "#artifacts", number: "07", category: "CONTAINERS", title: "SYSTEM ARTIFACTS", wide: true },
];
---

<BaseLayout title="Levy | Architectural Component Library">
    <Header />
    <BentoNav items={navItems} />

    <main>
        <!-- COVER -->
        <section id="cover" style="padding-top: calc(var(--space-24) * 1.5);">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="micro-data lbl-lead">MATHEMATICAL SCALING</span><span class="micro-data">ASTRO READY</span></div>
                <h1 class="hd-main tech-title display-huge reveal">DESIGN SYSTEM</h1>
                <div class="txt-block reveal p-group" style="margin-top: var(--space-4);">
                    <h3 class="narrative" style="font-size: var(--step-3);">The atomic components and architectural blueprint for Levy. Governed by a strict base-8 grid and perfect-fourth typographic scale.</h3>
                </div>
            </div>
        </section>

        <!-- TYPOGRAPHY -->
        <section id="typography">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="micro-data lbl-lead">01 // TYPOGRAPHY</span></div>
                <div class="txt-wide reveal p-group">
                    <h2 class="tech-title display-large">ARCHITECTURAL SCALE</h2>
                    <hr class="divider">
                </div>

                <div class="split-2up reveal">
                    <div class="split-l p-group">
                        <span class="micro-data lbl-lead">HEADING SCALE (RATIO: 1.333)</span>
                        <div class="display-massive tech-title">MASSIVE</div>
                        <div class="display-huge tech-title">HUGE</div>
                        <div class="display-large tech-title">LARGE</div>
                        <div class="display-medium tech-title">MEDIUM</div>
                    </div>

                    <div class="split-r p-group">
                        <span class="micro-data lbl-lead">READING & INLINE</span>
                        <div class="narrative" style="margin-bottom: var(--space-4); font-size: var(--step-3);">Narrative display font for insight blocks.</div>
                        <p class="body-large"><strong>Body Large:</strong> The gap between what capable people are building and what they could be building is not a motivation problem. It's a structural one.</p>
                        <p class="body-medium"><strong>Body Medium:</strong> This is standard paragraph text. It supports <em>italic emphasis</em>, <strong>bold strength</strong>, and <a href="#" class="text-link">inline text links</a> for cross-referencing.</p>
                        <p class="body-small"><strong>Body Small:</strong> Used for captions, disclaimers, and metadata.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- BUTTONS & BADGES -->
        <section id="buttons">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="micro-data lbl-lead">02 // INTERACTION</span></div>
                <div class="txt-wide reveal p-group">
                    <h2 class="tech-title display-medium">BUTTONS & BADGES</h2>
                    <hr class="divider">
                </div>

                <div class="split-2up reveal">
                    <div class="split-l p-group" style="align-items: flex-start;">
                        <span class="micro-data lbl-lead">PRIMARY ACTIONS (H: 48PX)</span>
                        <div class="btn-group">
                            <Button variant="solid" label="Solid Button" />
                            <Button variant="ghost" label="Ghost Button" />
                        </div>
                    </div>
                    <div class="split-r p-group" style="align-items: flex-start;">
                        <span class="micro-data lbl-lead">SYSTEM BADGES (H: 32PX)</span>
                        <div class="btn-group">
                            <Badge label="Active" />
                            <Badge label="In Progress" />
                            <Badge label="Archived" opacity={0.5} />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- FORM CONTROLS -->
        <section id="forms">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="micro-data lbl-lead">03 // INPUT</span></div>
                <div class="txt-wide reveal p-group">
                    <h2 class="tech-title display-medium">FORM CONTROLS</h2>
                    <hr class="divider">
                </div>

                <div class="split-2up reveal">
                    <div class="split-l">
                        <FormInput label="Full Name" placeholder="e.g. Jane Doe" />
                        <FormSelect label="Institution Type" options={["Select an option...", "Federal Government", "Private Sector", "Non-Profit"]} />
                        <div class="form-row" style="margin-top: var(--space-2);">
                            <span class="form-label" style="margin-bottom: var(--space-1); display: block;">Interests</span>
                            <div class="control-group">
                                <FormCheckbox label="Levy Network" checked />
                                <FormCheckbox label="Levy Studio" />
                            </div>
                        </div>
                    </div>
                    <div class="split-r">
                        <FormTextarea label="Project Description" placeholder="Describe the structural gap..." />
                        <div class="form-row" style="margin-top: var(--space-2);">
                            <span class="form-label" style="margin-bottom: var(--space-1); display: block;">Visibility</span>
                            <div class="control-group">
                                <FormRadio label="Public" name="vis" checked />
                                <FormRadio label="Internal Only" name="vis" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- MEDIA RATIOS -->
        <section id="media">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="micro-data lbl-lead">04 // IMAGERY</span></div>
                <div class="txt-wide reveal p-group">
                    <h2 class="tech-title display-medium">MEDIA RATIOS</h2>
                    <hr class="divider">
                </div>

                <div class="txt-wide reveal" style="margin-bottom: var(--space-4);">
                    <MediaPlaceholder ratio="16:9" caption="Widescreen Format (16:9) - Used for primary hero elements and video." />
                </div>

                <div class="split-2up reveal">
                    <div class="split-l">
                        <MediaPlaceholder ratio="4:3" caption="Standard Format (4:3) - Used for editorial content." />
                    </div>
                    <div class="split-r">
                        <MediaPlaceholder ratio="1:1" caption="Square Format (1:1) - Used for portraits and grid galleries." />
                    </div>
                </div>
            </div>
        </section>

        <!-- ACCORDIONS -->
        <section id="accordions">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="micro-data lbl-lead">05 // TOGGLES</span></div>
                <div class="txt-wide reveal p-group">
                    <h2 class="tech-title display-medium">ACCORDIONS (GRID ANIMATED)</h2>

                    <div class="reveal" style="margin-top: var(--space-6);">
                        <AccordionWrapper>
                            <Accordion title="What is the Levy Studio?" open>
                                <p class="body-medium">The portfolio and program-building arm. Designing, launching, and scaling initiatives that demonstrate what cross-sector coalition building actually produces.</p>
                            </Accordion>
                            <Accordion title="How does the community capital framework apply?">
                                <p class="body-medium">Durable outcomes require simultaneous investment across the forms of capital a community runs on — human, social, cultural, financial, built, and political.</p>
                            </Accordion>
                            <Accordion title="Is Levy a political organization?">
                                <p class="body-medium">No. Levy operates as a builder, working in the places and with the people where the promise of the American Project is most actively being tested. It is strictly non-partisan.</p>
                            </Accordion>
                        </AccordionWrapper>
                    </div>
                </div>
            </div>
        </section>

        <!-- TABLES -->
        <section id="data">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="micro-data lbl-lead">06 // STRUCTURE</span></div>
                <div class="txt-wide reveal p-group">
                    <h2 class="tech-title display-medium">TABLES</h2>
                    <hr class="divider">
                </div>

                <div class="txt-wide reveal">
                    <SystemTable>
                        <thead>
                            <tr>
                                <th>Component</th>
                                <th>Status</th>
                                <th>Deployment Phase</th>
                                <th>Primary Metric</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Studio OS</td>
                                <td><Badge label="Active" /></td>
                                <td>Public Library System</td>
                                <td>Cohorts Launched</td>
                            </tr>
                            <tr>
                                <td>Levy Institute</td>
                                <td><Badge label="Beta" /></td>
                                <td>Academic Research</td>
                                <td>Frameworks Published</td>
                            </tr>
                            <tr>
                                <td>The Network</td>
                                <td><Badge label="Scaling" /></td>
                                <td>Washington D.C. Node</td>
                                <td>Active Members</td>
                            </tr>
                        </tbody>
                    </SystemTable>
                </div>
            </div>
        </section>

        <!-- ARTIFACTS -->
        <section id="artifacts">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="micro-data lbl-lead">07 // CONTAINERS</span></div>
                <div class="txt-wide reveal p-group">
                    <h2 class="tech-title display-medium">SYSTEM ARTIFACTS</h2>

                    <Blockquote>"Those aren't two separate arguments. They're the same one."</Blockquote>
                </div>

                <div class="split-2up reveal">
                    <div class="split-l stack-group">
                        <span class="micro-data lbl-lead">ARTIFACT CARDS (STACK COLLAPSED)</span>
                        <ArtifactCard badge="CORE TENET" title="THE LEVY NETWORK">
                            <p class="body-medium">The membership community built to make members sharper, better connected, and better equipped.</p>
                        </ArtifactCard>
                        <ArtifactCard badge="PROGRAM" title="THE LEVY STUDIO">
                            <p class="body-medium">The portfolio and program-building arm. Designing and scaling initiatives.</p>
                        </ArtifactCard>
                    </div>
                    <div class="split-r">
                        <span class="micro-data lbl-lead">DO / DON'T BOXES</span>
                        <DoDontBox rule="DIRECT TONE">
                            <p class="body-medium">Speak to people who are already serious and already working. Earn your sentences. Never flatter.</p>
                        </DoDontBox>
                    </div>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .form-row { display: flex; flex-direction: column; gap: var(--space-1); margin-bottom: var(--space-4); width: 100%; }
    .form-label { font-family: var(--font-tech); font-size: var(--step--1); text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink); }
</style>
