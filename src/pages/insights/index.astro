---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import BentoNav from '../../components/BentoNav.astro';
import StatementBreakout from '../../components/StatementBreakout.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import InsightCard from '../../components/InsightCard.astro';
import { fetchPosts } from '../../lib/rss';
import { TIER_MAP } from '../../lib/tiers';
import { NAV_ITEMS } from '../../lib/nav';

const posts = await fetchPosts('https://rss.beehiiv.com/feeds/fwVb8aZ2Qa.xml');
---

<BaseLayout title="Insights — Levy Strategic Design" description="Essays, analysis, and field-level signal from Levy.">
    <Header />
    <BentoNav items={NAV_ITEMS} currentPath="/insights" />

    <main id="main-content">
        <h1 class="sr-only">Insights from Levy Strategic Design</h1>
        <StatementBreakout
            id="cover"
            topNarrative="Field-level signal."
            mainLeft="INSIGHTS&nbsp;:"
            mainRightTop="FROM"
            mainRightBottom="THE FIELD"
            bottomNarrative="Essays. Analysis. Signal before consensus."
        />

        <section id="insights">
            <div class="layout-grid">
                <div class="lbl reveal-left"><span class="section-label">01 // SIGNAL</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">FROM THE FIELD</h2>
                </div>
                <div class="txt-block reveal">
                    <p class="body-large">Executive essays on how systems work and where the leverage is, field-level signal before it becomes consensus, and curated analysis at the intersection of builders and institutions.</p>
                </div>

                {posts.length > 0 ? (
                    <div class="split-3up insights-grid reveal-stagger">
                        {posts.map((post) => (
                            <InsightCard
                                title={post.title}
                                href={`/insights/${post.slug}`}
                                date={post.pubDate}
                                excerpt={post.description}
                                tier={post.tier}
                                tierLabel={post.tierLabel}
                                tierLevel={post.tierLevel}
                                tierUid={post.tierUid}
                            />
                        ))}
                    </div>
                ) : (
                    <div class="txt-block reveal">
                        <p class="body-large">New posts coming soon. Subscribe to get them first.</p>
                    </div>
                )}

                <div class="txt-block reveal">
                    <p class="marginalia">Insider members receive this monthly. The public archive is below.</p>
                </div>
            </div>
        </section>
    </main>

    <SiteFooter />
</BaseLayout>

<style>
    .insights-grid {
        max-width: 1200px;
    }
</style>

<script>
    /**
     * Waterfall Content Gate — Grid-level gating logic.
     * Adjusts InsightCard CTAs based on the user's Outseta auth state.
     */

    const TIER_CONFIG: Record<string, { level: number; uid: string | null; label: string }> = {
        architect: { level: 4, uid: 'LmJ47j9P', label: 'Architect' },
        builder:   { level: 3, uid: 'rmk5w09g', label: 'Builder' },
        insider:   { level: 2, uid: 'Nmdndw90', label: 'Insider' },
        free:      { level: 1, uid: 'MQvb4oQY', label: 'Free' },
        public:    { level: 0, uid: null,        label: 'Public' },
    };

    function getUserLevel(user: any): number {
        if (!user) return 0;
        const planUid = user?.Account?.CurrentSubscription?.Plan?.Uid;
        if (!planUid) return 0;
        for (const tier of Object.values(TIER_CONFIG)) {
            if (tier.uid === planUid) return tier.level;
        }
        return 0;
    }

    function applyGating(user: any) {
        const userLevel = getUserLevel(user);
        const gatedCards = document.querySelectorAll<HTMLAnchorElement>('.insight-card[data-tier-level]');

        gatedCards.forEach((card) => {
            const postLevel = parseInt(card.dataset.tierLevel || '0', 10);
            const tier = card.dataset.tier || 'public';
            const cta = card.querySelector<HTMLSpanElement>('.insight-cta');

            if (postLevel === 0) return; // Public posts — no gating needed

            if (userLevel >= postLevel) {
                // Authorized — restore normal behavior
                card.classList.add('is-authorized');
                if (cta) cta.innerHTML = 'Read more &rarr;';
            } else if (user) {
                // Logged in but insufficient tier — show upgrade CTA
                const tierInfo = TIER_CONFIG[tier];
                const upgradeUid = tierInfo?.uid || '';
                if (cta) cta.innerHTML = `Upgrade to ${tierInfo?.label || 'Premium'} &rarr;`;
                card.addEventListener('click', (e) => {
                    if (userLevel < postLevel) {
                        e.preventDefault();
                        window.location.href = `https://levy.outseta.com/auth?widgetMode=register&planUid=${upgradeUid}#o-anonymous`;
                    }
                });
            } else {
                // Not logged in — show sign-in CTA
                if (cta) cta.innerHTML = 'Sign in to read &rarr;';
                card.addEventListener('click', (e) => {
                    if (!user) {
                        e.preventDefault();
                        const Outseta = (window as any).Outseta;
                        if (Outseta?.auth?.open) {
                            Outseta.auth.open({ widgetMode: 'login' });
                        } else {
                            window.location.href = 'https://levy.outseta.com/auth?widgetMode=login#o-anonymous';
                        }
                    }
                });
            }
        });
    }

    function waitForOutseta(callback: (Outseta: any) => void) {
        const check = () => {
            const Outseta = (window as any).Outseta;
            if (Outseta?.getUser) {
                callback(Outseta);
            } else {
                setTimeout(check, 200);
            }
        };
        check();
    }

    document.addEventListener('DOMContentLoaded', () => {
        waitForOutseta(async (Outseta) => {
            try {
                const user = await Outseta.getUser();
                applyGating(user);
            } catch {
                applyGating(null);
            }
        });
    });
</script>
