---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BentoNav from '../components/BentoNav.astro';
import StatementBreakout from '../components/StatementBreakout.astro';

const navItems = [
    { href: "/#problem",    number: "01", category: "CONTEXT",    title: "THE PROBLEM" },
    { href: "/#model",      number: "02", category: "COMPANY",    title: "THE MODEL", wide: true },
    { href: "/#outcomes",   number: "03", category: "OUTCOMES",   title: "WHAT MEMBERS GET", wide: true },
    { href: "/#who",        number: "04", category: "FIT",        title: "WHO IT'S FOR" },
    { href: "/#membership", number: "05", category: "MEMBERSHIP", title: "THREE WAYS IN" },
];
---

<BaseLayout title="About — Levy Strategic Design" description="The story behind Levy Strategic Design.">
    <Header />
    <BentoNav items={navItems} />

    <main id="main-content">
        <h1 class="sr-only">About Levy Strategic Design</h1>
        <StatementBreakout
            id="cover"
            topNarrative="The company."
            mainLeft="ABOUT&nbsp;:"
            mainRightTop="LEVY"
            mainRightBottom="STRATEGIC"
            bottomNarrative="Washington, D.C."
        />

        <section id="about">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">01 // COMPANY</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">COMING SOON</h2>
                </div>
                <div class="txt-block reveal">
                    <p class="body-large">This page is under construction. Levy Strategic Design helps serious people develop the capabilities to navigate the human systems that determine whether their work reaches the scale it deserves.</p>
                </div>
                <div class="txt-block reveal">
                    <p class="marginalia">Check back soon for the full story.</p>
                </div>
            </div>
        </section>
    </main>

    <StatementBreakout
        theme="dark"
        mainLeft="BUILD&nbsp;:"
        mainRightTop="THE"
        mainRightBottom="ROOM"
        marginaliaBottomLeft="LEVY STRATEGIC DESIGN // WASHINGTON, D.C."
        marginaliaBottomRight="EST. 2024"
    />
</BaseLayout>
