---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BentoNav from '../components/BentoNav.astro';
import StatementBreakout from '../components/StatementBreakout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Button from '../components/Button.astro';
import { NAV_ITEMS } from '../lib/nav';
---

<BaseLayout title="About — Levy Strategic Design" description="The story behind Levy Strategic Design.">
    <Header />
    <BentoNav items={NAV_ITEMS} currentPath="/about" />

    <main id="main-content">
        <h1 class="sr-only">About Levy Strategic Design</h1>
        <StatementBreakout
            id="cover"
            topNarrative="The company."
            mainLeft="ABOUT&nbsp;:"
            mainRightTop="LEVY"
            mainRightBottom="STRATEGIC"
            bottomNarrative="Washington, D.C."
        />

        <section id="about">
            <div class="layout-grid">
                <div class="lbl reveal"><span class="section-label">01 // COMPANY</span></div>
                <div class="txt-wide reveal">
                    <h2 class="tech-title display-large">THE COMPANY</h2>
                </div>
                <div class="txt-block reveal">
                    <p class="body-large">Levy Strategic Design helps serious people develop the capabilities to navigate the human systems that determine whether their work reaches the scale it deserves.</p>
                </div>
                <div class="txt-block reveal">
                    <p class="body-large">One company. Three functions: a Network where the collision happens, a Studio that builds what serious work requires, and an Institute that develops the methods. Each arm feeds the others.</p>
                </div>
                <div class="txt-block reveal">
                    <p class="marginalia">Full story coming soon. In the meantime — explore.</p>
                </div>
                <div class="txt-wide reveal" style="margin-top: var(--space-4); display: flex; gap: var(--space-4); flex-wrap: wrap;">
                    <Button variant="solid" href="/join" label="Explore membership" />
                    <Button variant="ghost" href="/insights" label="Read our insights" />
                </div>
            </div>
        </section>
    </main>

    <SiteFooter />
</BaseLayout>
