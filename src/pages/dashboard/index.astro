---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import BentoNav from '../../components/BentoNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { NAV_ITEMS } from '../../lib/nav';
---

<BaseLayout title="Dashboard — Levy Network" description="Your Levy Network member dashboard.">
    <Header />
    <BentoNav items={NAV_ITEMS} currentPath="/dashboard" />

    <main id="main-content">
        <h1 class="sr-only">Member Dashboard</h1>
        <section class="void-section">
            <div data-o-profile="1" data-mode="embed"></div>
        </section>
    </main>

    <SiteFooter />
</BaseLayout>
