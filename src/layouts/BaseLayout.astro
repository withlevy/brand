---
interface Props {
    title: string;
    description?: string;
    ogImage?: string;
    type?: 'website' | 'article';
}

const { title, description = 'Levy Design System', ogImage = '/og-default.png', type = 'website' } = Astro.props;
const canonicalURL = Astro.url.href;

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="canonical" href={canonicalURL}>

    <!-- Open Graph -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content={type}>
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:image" content={new URL(ogImage, Astro.url).href}>

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={new URL(ogImage, Astro.url).href}>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,100..400&display=swap" rel="stylesheet">

    <script is:inline>
    var o_options = {
        domain: 'levy.outseta.com',
        load: 'auth,customForm,emailList,leadCapture,nocode,profile,support',
        auth: {
            authenticationCallbackUrl: window.location.origin + '/dashboard',
            registrationConfirmationUrl: window.location.origin + '/dashboard',
            passwordResetUrl: window.location.origin + '/login'
        }
    };
    </script>
    <script src="https://cdn.outseta.com/outseta.min.js" data-options="o_options" is:inline></script>

    <!-- Outseta lifecycle: mirror access token to cookie for SSR JWT gating;
         redirect on logout; toggle header Login<->Account. -->
    <script is:inline>
    (function () {
      function cookieSecureFlag() {
        return window.location.protocol === 'https:' ? '; Secure' : '';
      }
      function setTokenCookie(token) {
        if (!token) return;
        document.cookie = 'outseta_token=' + token + '; path=/; max-age=86400; SameSite=Lax' + cookieSecureFlag();
      }
      function clearTokenCookie() {
        document.cookie = 'outseta_token=; path=/; max-age=0; SameSite=Lax' + cookieSecureFlag();
      }
      function applyAuthState(user) {
        var joinLink = document.querySelector('.header-join');
        if (!joinLink) return;
        if (user) {
          joinLink.textContent = 'Account';
          joinLink.setAttribute('href', '/dashboard');
          joinLink.setAttribute('aria-label', 'Your Levy member hub');
        } else {
          joinLink.textContent = 'Login';
          joinLink.setAttribute('href', '/login');
          joinLink.setAttribute('aria-label', 'Sign in to your account');
        }
        document.body.classList.toggle('is-authenticated', !!user);
        document.body.classList.toggle('is-anonymous', !user);
      }

      function bootstrap() {
        if (!window.Outseta) return;
        var token = Outseta.getAccessToken && Outseta.getAccessToken();
        if (token) setTokenCookie(token);
        Outseta.getUser
          ? Outseta.getUser().then(applyAuthState).catch(function () { applyAuthState(null); })
          : applyAuthState(null);

        Outseta.on('accessToken.set', function (t) { setTokenCookie(t); });
        Outseta.on('login', function () {
          var t = Outseta.getAccessToken && Outseta.getAccessToken();
          if (t) setTokenCookie(t);
          Outseta.getUser().then(applyAuthState);
        });
        Outseta.on('logout', function () {
          clearTokenCookie();
          applyAuthState(null);
          window.location.href = '/signed-out';
        });
        Outseta.on('subscription.update', function () {
          Outseta.getUser().then(applyAuthState);
        });
      }

      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        setTimeout(bootstrap, 0);
      } else {
        document.addEventListener('DOMContentLoaded', bootstrap);
      }
    })();
    </script>
</head>
<body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="noise"></div>

    <slot />

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Scroll Reveal Logic
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("is-visible");
                    }
                });
            }, { threshold: prefersReducedMotion ? 0 : 0.1 });

            document.querySelectorAll(".reveal, .reveal-left, .reveal-stagger").forEach(el => revealObserver.observe(el));
        });
    </script>
</body>
</html>
